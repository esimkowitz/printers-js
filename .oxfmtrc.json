{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": true,
  "trailingComma": "es5",
  "singleQuote": false,
  "printWidth": 80,
  "tabWidth": 2,
  "useTabs": false,
  "endOfLine": "lf",
  "arrowParens": "avoid",
  "proseWrap": "preserve",
  "quoteProps": "as-needed",
  "bracketSpacing": true,
  "bracketSameLine": false,
  "jsxSingleQuote": false,
  "sortPackageJson": false,
  "ignorePatterns": [
    "target/",
    "npm/",
    "coverage/",
    "reports/",
    "test-results/",
    ".claude/",
    "dist/",
    "node_modules/",
    "*.lock",
    "*.log",
    "pnpm-lock.yaml",
    "Cargo.toml",
    "Cargo.lock",
    "LICENSE",
    "*.rs",
    "*.node"
  ]
}
