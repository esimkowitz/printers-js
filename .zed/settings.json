{
  "lsp": {
    "typescript-language-server": {
      "settings": {
        "suggest": {
          "autoImports": true,
          "completeFunctionCalls": false,
          "paths": true
        }
      }
    }
  },
  "languages": {
    "TypeScript": {
      "language_servers": [
        "typescript-language-server",
        "oxc",
        "!deno",
        "!vtsls"
      ],
      "formatter": {
        "external": {
          "command": "pnpm",
          "arguments": ["exec", "oxfmt", "--stdin-filepath", "{buffer_path}"]
        }
      }
    },
    "TSX": {
      "language_servers": [
        "typescript-language-server",
        "oxc",
        "!deno",
        "!vtsls"
      ],
      "formatter": {
        "external": {
          "command": "pnpm",
          "arguments": ["exec", "oxfmt", "--stdin-filepath", "{buffer_path}"]
        }
      }
    },
    "JavaScript": {
      "language_servers": [
        "typescript-language-server",
        "oxc",
        "!deno",
        "!vtsls"
      ],
      "formatter": {
        "external": {
          "command": "pnpm",
          "arguments": ["exec", "oxfmt", "--stdin-filepath", "{buffer_path}"]
        }
      }
    },
    "JSON": {
      "formatter": {
        "external": {
          "command": "pnpm",
          "arguments": ["exec", "oxfmt", "--stdin-filepath", "{buffer_path}"]
        }
      }
    },
    "JSONC": {
      "formatter": {
        "external": {
          "command": "pnpm",
          "arguments": ["exec", "oxfmt", "--stdin-filepath", "{buffer_path}"]
        }
      }
    },
    "Markdown": {
      "formatter": {
        "external": {
          "command": "pnpm",
          "arguments": ["exec", "oxfmt", "--stdin-filepath", "{buffer_path}"]
        }
      }
    },
    "YAML": {
      "formatter": {
        "external": {
          "command": "pnpm",
          "arguments": ["exec", "oxfmt", "--stdin-filepath", "{buffer_path}"]
        }
      }
    }
  },
  "auto_indent_on_paste": true,
  "format_on_save": "on",
  "file_scan_exclusions": [
    "**/.git",
    "**/.DS_Store",
    "**/.vscode/extensions",
    "**/npm",
    "**/target",
    "**/dist",
    "**/coverage"
  ]
}
